# =============================================================================
# mobentis-infrastructure environment variables
# =============================================================================
# Copy this to .env and fill in your values.
# WARNING: .env contains secrets — never commit to version control.

# --- Domain ---
DOMAIN=example.com

# --- Email (Alertmanager notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme
ALERT_EMAIL_TO=team@example.com

# --- Postgres ---
POSTGRES_USER=mobentis
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mobentis

# --- Redis ---
REDIS_PASSWORD=changeme

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# --- General ---
ENV=production
REGION=default
DATA_DIR=/data
